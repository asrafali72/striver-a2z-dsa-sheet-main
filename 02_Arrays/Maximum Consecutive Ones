/*
Problem: Max Consecutive Ones
Platform: LeetCode

Approach:
Traverse the array and count consecutive 1s.
If the current element is 1, increment the counter.
If it is 0, reset the counter to 0.
Keep track of the maximum value of the counter during traversal.

Time Complexity: O(n)
Space Complexity: O(1)
*/

class Solution {
public:
    int findMaxConsecutiveOnes(vector<int>& nums) {

        int count = 0, maxi = 0;

        for(int i = 0; i < nums.size(); i++){
            if(nums[i] == 1)
                count++;
            else
                count = 0;

            maxi = max(maxi, count);
        }

        return maxi;
    }
};
