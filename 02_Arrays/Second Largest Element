/*
Problem: Second Largest Element in an Array

Platform: GeeksforGeeks

Problem Statement:
Given an array of integers, find the second largest element in the array.
If the second largest element does not exist, return -1.

Example:
Input: arr = [12, 35, 1, 10, 34, 1]
Output: 34

Explanation:
The largest element is 35 and the second largest element is 34.

Approach:
- Maintain two variables:
    l  -> largest element
    l2 -> second largest element
- Initialize:
    l = arr[0]
    l2 = -1
- Traverse the array:
    1. If current element > l
        - update second largest (l2 = l)
        - update largest (l = arr[i])
    2. If current element is smaller than largest but greater than second largest
        - update second largest
- After traversal, return l2.

Time Complexity: O(n)
We traverse the array only once.

Space Complexity: O(1)
No extra space is used.
*/

class Solution {
public:
    int getSecondLargest(vector<int> &arr) {

        int l = arr[0];
        int l2 = -1;

        for(int i = 0; i < arr.size(); i++){

            if(l < arr[i]){
                l2 = l;
                l = arr[i];
            }

            if(arr[i] < l && l2 < arr[i])
                l2 = arr[i];
        }

        return l2;
    }
};
